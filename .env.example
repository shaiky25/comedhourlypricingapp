# ComEd notifier — copy to .env and fill in at least one delivery method.
# Use alerts to run EV charging / washer / dryer when hourly price is low.

# Illinois / ComEd local time
COMED_TZ=America/Chicago

# Only consider alerts during these local clock hours (0–23), inclusive.
# Default 5–23 = 5 AM through 11 PM (original behavior).
# 24h monitoring (including overnight EV windows): use 0 and 23.
# Overnight-only band (e.g. 10 PM–6 AM): ALERT_WINDOW_START_HOUR=22 ALERT_WINDOW_END_HOUR=6
ALERT_WINDOW_START_HOUR=5
ALERT_WINDOW_END_HOUR=23

# Alert when current-hour average is strictly below this many cents per kWh
PRICE_THRESHOLD_CENTS=3

# --- Email (SMTP) — set all five to enable ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=app-password-here
ALERT_EMAIL_TO=you@gmail.com

# --- SMS (Twilio) — set all three to enable ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
ALERT_SMS_TO=+1xxxxxxxxxx

# --- GitHub Actions (optional cloud deploy) ---
# Copy this repo to GitHub, then Settings → Secrets → Actions: add each variable above
# under the same names. Workflow: .github/workflows/comed-pricing.yml
